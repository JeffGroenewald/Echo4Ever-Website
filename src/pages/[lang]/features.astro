---
import Base from '../../layouts/Base.astro';
import FeaturesPage from '../../components/pages/FeaturesPage.astro';
import { getTranslations, getNonDefaultLocales } from '../../i18n/utils';

export function getStaticPaths() {
  return getNonDefaultLocales().map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = getTranslations(lang!);
---

<Base title={t.meta.featuresTitle} description={t.meta.featuresDescription} lang={lang!}>
  <FeaturesPage t={t} lang={lang!} />
</Base>
