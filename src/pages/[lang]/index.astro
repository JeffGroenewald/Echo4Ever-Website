---
import Base from '../../layouts/Base.astro';
import HomePage from '../../components/pages/HomePage.astro';
import { getTranslations, getNonDefaultLocales } from '../../i18n/utils';

export function getStaticPaths() {
  return getNonDefaultLocales().map((lang) => ({ params: { lang } }));
}

const { lang } = Astro.params;
const t = getTranslations(lang!);
---

<Base title={t.meta.indexTitle} description={t.meta.indexDescription} lang={lang!}>
  <HomePage t={t} lang={lang!} />
</Base>
