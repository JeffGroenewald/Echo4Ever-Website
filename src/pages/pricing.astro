---
import Base from '../layouts/Base.astro';
---

<Base title="Pricing — Echo4Ever" description="Simple, honest pricing. Three plans, all features included. Choose the storage you need.">

  <section class="page-header">
    <div class="container">
      <h1>Simple, honest pricing</h1>
      <p>All plans include every feature. Choose the storage that fits your life.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">

      <!-- Country selector -->
      <div class="currency-select text-center">
        <label for="country" class="text-secondary">Select your country:</label>
        <select id="country">
          <option value="" selected disabled>-- Select your country --</option>
          <option value="NZ">New Zealand</option>
          <option value="AU">Australia</option>
          <option value="US">United States</option>
          <option value="GB">United Kingdom</option>
          <option value="CA">Canada</option>
          <option value="IE">Ireland</option>
          <option value="ZA">South Africa</option>
          <option value="DE">Germany</option>
          <option value="FR">France</option>
          <option value="IT">Italy</option>
          <option value="ES">Spain</option>
          <option value="NL">Netherlands</option>
          <option value="BE">Belgium</option>
          <option value="AT">Austria</option>
          <option value="CH">Switzerland</option>
          <option value="SE">Sweden</option>
          <option value="NO">Norway</option>
          <option value="DK">Denmark</option>
          <option value="FI">Finland</option>
          <option value="PT">Portugal</option>
          <option value="JP">Japan</option>
          <option value="SG">Singapore</option>
          <option value="IN">India</option>
          <option value="BR">Brazil</option>
          <option value="MX">Mexico</option>
          <option value="AR">Argentina</option>
          <option value="CL">Chile</option>
          <option value="CO">Colombia</option>
          <option value="PH">Philippines</option>
          <option value="MY">Malaysia</option>
          <option value="TH">Thailand</option>
          <option value="ID">Indonesia</option>
          <option value="KR">South Korea</option>
          <option value="AE">United Arab Emirates</option>
          <option value="SA">Saudi Arabia</option>
          <option value="EG">Egypt</option>
          <option value="KE">Kenya</option>
          <option value="NG">Nigeria</option>
          <option value="GH">Ghana</option>
          <option value="OTHER">Other</option>
        </select>
      </div>

      <div class="grid grid--3 pricing-grid" id="pricing-grid" style="display: none;">

        <!-- Foundation -->
        <div class="pricing-card">
          <h3>Foundation</h3>
          <p class="pricing-storage">25 GB storage</p>
          <div class="pricing-price" data-prices='{"NZD":"13.99","USD":"16.99","AUD":"13.99","EUR":"12.99"}'>
          </div>
          <p class="pricing-interval">per month</p>
          <ul class="pricing-features">
            <li>Photo, video &amp; audio uploads</li>
            <li>Document storage</li>
            <li>Life Story with prompts</li>
            <li>Family Tree builder</li>
            <li>Family sharing</li>
            <li>Time capsules</li>
            <li>Digital legacy planning</li>
          </ul>
          <a href="https://app.echo4ever.com/signup" class="btn btn--outline">Get Started</a>
        </div>

        <!-- Legacy -->
        <div class="pricing-card pricing-card--popular">
          <span class="pricing-badge">Most Popular</span>
          <h3>Legacy</h3>
          <p class="pricing-storage">100 GB storage</p>
          <div class="pricing-price" data-prices='{"NZD":"15.99","USD":"17.99","AUD":"15.99","EUR":"13.99"}'>
          </div>
          <p class="pricing-interval">per month</p>
          <ul class="pricing-features">
            <li>Photo, video &amp; audio uploads</li>
            <li>Document storage</li>
            <li>Life Story with prompts</li>
            <li>Family Tree builder</li>
            <li>Family sharing</li>
            <li>Time capsules</li>
            <li>Digital legacy planning</li>
          </ul>
          <a href="https://app.echo4ever.com/signup" class="btn btn--primary">Get Started</a>
        </div>

        <!-- Generations -->
        <div class="pricing-card">
          <h3>Generations</h3>
          <p class="pricing-storage">250 GB storage</p>
          <div class="pricing-price" data-prices='{"NZD":"19.99","USD":"19.99","AUD":"19.99","EUR":"18.99"}'>
          </div>
          <p class="pricing-interval">per month</p>
          <ul class="pricing-features">
            <li>Photo, video &amp; audio uploads</li>
            <li>Document storage</li>
            <li>Life Story with prompts</li>
            <li>Family Tree builder</li>
            <li>Family sharing</li>
            <li>Time capsules</li>
            <li>Digital legacy planning</li>
          </ul>
          <a href="https://app.echo4ever.com/signup" class="btn btn--outline">Get Started</a>
        </div>

      </div>

      <p class="text-center text-secondary" id="pricing-note" style="margin-top: 40px; font-size: var(--font-size-caption); display: none;">
        All plans include every feature. The only difference is storage. Upgrade or downgrade any time.
      </p>

    </div>
  </section>

  <!-- FAQ -->
  <section class="section section--alt">
    <div class="container" style="max-width: 720px;">
      <h2 class="text-center" style="margin-bottom: 40px;">Common questions</h2>

      <div class="faq-item">
        <h3>Can I change my plan later?</h3>
        <p class="text-secondary">Absolutely. Upgrade or downgrade at any time from your account settings. Changes are prorated — you only pay the difference.</p>
      </div>

      <div class="faq-item">
        <h3>What file types can I upload?</h3>
        <p class="text-secondary">Photos (JPG, PNG, GIF), videos (MP4, MOV), audio (MP3, M4A, WAV), and documents (PDF, DOC, DOCX). Up to 500 MB per file.</p>
      </div>

      <div class="faq-item">
        <h3>Who can see my memories?</h3>
        <p class="text-secondary">Only you — unless you choose to share. Every memory starts private. There are no public profiles, no social feeds, and no algorithms.</p>
      </div>

      <div class="faq-item">
        <h3>What is a Heritage Custodian?</h3>
        <p class="text-secondary">Someone you trust to manage your digital legacy. When the time comes, they can activate your account so the memories you've chosen are shared with the people you've named.</p>
      </div>

      <div class="faq-item">
        <h3>Can I cancel any time?</h3>
        <p class="text-secondary">Yes. No contracts, no penalties. Cancel from your account settings and you'll keep access until the end of your billing period.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="cta-banner">
    <div class="container">
      <h2>Start preserving what matters</h2>
      <p>Your memories deserve a proper home. Pick a plan and begin today.</p>
      <a href="https://app.echo4ever.com/signup" class="btn btn--primary btn--large">Create Your Archive</a>
    </div>
  </section>

</Base>

<style>
  .currency-select {
    margin-bottom: 40px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: var(--color-accent);
    border: 1px solid var(--color-accent);
    border-radius: var(--radius-card);
    padding: 40px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
    position: relative;
    z-index: 1;
  }

  .currency-select label {
    font-size: 24px;
    font-weight: 600;
    color: var(--color-accent-text);
  }

  .currency-select select {
    font-family: var(--font-body);
    font-size: 24px;
    padding: 16px 24px;
    border: 2px solid var(--color-accent);
    border-radius: 8px;
    background: #ffffff;
    color: #1E2A2A;
    cursor: pointer;
    min-width: 360px;
  }

  .pricing-grid {
    align-items: start;
  }

  @media (max-width: 768px) {
    .currency-select select {
      width: 100%;
      min-width: unset;
      font-size: 20px;
      padding: 14px 16px;
    }
    .currency-select label {
      font-size: 20px;
    }
  }

  .faq-item {
    padding: 24px 0;
    border-bottom: 1px solid var(--color-border);
  }

  .faq-item:first-of-type {
    border-top: 1px solid var(--color-border);
  }

  .faq-item h3 {
    margin-bottom: 8px;
    font-size: var(--font-size-subheading);
  }

  .faq-item p {
    margin: 0;
  }
</style>

<script>
  const eurCountries = ['DE','FR','IT','ES','NL','BE','AT','CH','SE','NO','DK','FI','PT','IE','GB'];

  function getCurrency(countryCode: string): string {
    if (countryCode === 'NZ') return 'NZD';
    if (countryCode === 'AU') return 'AUD';
    if (eurCountries.includes(countryCode)) return 'EUR';
    return 'USD';
  }

  const symbols: Record<string, string> = { NZD: 'NZ$', USD: 'US$', AUD: 'AU$', EUR: '€' };

  function updatePrices() {
    const countrySelect = document.getElementById('country') as HTMLSelectElement;
    const countryCode = countrySelect.value;
    if (!countryCode) return;

    const pricingGrid = document.getElementById('pricing-grid');
    const pricingNote = document.getElementById('pricing-note');
    if (pricingGrid) pricingGrid.style.display = '';
    if (pricingNote) pricingNote.style.display = '';

    const currency = getCurrency(countryCode);
    const sym = symbols[currency] || '$';

    document.querySelectorAll('.pricing-price').forEach((el) => {
      const prices = JSON.parse(el.getAttribute('data-prices') || '{}');
      const price = prices[currency];
      if (price) {
        el.textContent = `${sym}${price}`;
      }
    });
  }

  document.getElementById('country')?.addEventListener('change', updatePrices);
</script>
